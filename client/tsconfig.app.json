{
  "extends": "@vue/tsconfig/tsconfig.dom.json",
  "include": ["env.d.ts", "src/**/*", "src/**/*.vue"],
  "exclude": [
    // exclude tests here if needed. ( don't know why )
    "dist"
  ],
  "compilerOptions": {
    "composite": true,
    "module": "ESNext",
    "target": "es2022",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "paths": {
      "@/*": ["./src/*"]
    }
  }
}
